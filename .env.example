# ─────────────────────────────────────────────────────────────────
# Praxis CENTCOM — environment template
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────


# ───── Core: Database + Auth (required for the app to start) ─────

# Supabase project — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk's SDK reads this directly from the env; not referenced by name in code.
CLERK_SECRET_KEY=


# ───── Integrations: PostHog (analytics + opt_ins KPI) ─────

# Client-side product analytics key (Settings → Project API Key).
NEXT_PUBLIC_POSTHOG_KEY=
# Defaults to https://app.posthog.com when blank. Set for self-hosted.
NEXT_PUBLIC_POSTHOG_HOST=

# Server-side Personal API Key with `query:read` scope. Used by
# /api/integrations/posthog/sync + /inspect to read events via HogQL.
# Generate at PostHog → avatar → Personal API keys.
POSTHOG_PERSONAL_API_KEY=
# Numeric project id (Project Settings → Project ID at the top).
POSTHOG_PROJECT_ID=


# ───── Integrations: AI (agents + KPI builder) ─────

# Anthropic key for /agents and components/reporting/AIKPIBuilder.tsx.
# Generate at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=


# ───── Integrations: Google Calendar + Drive (KPI source data) ─────

# Service-account JSON. Either inline (recommended for Vercel) or a path.
# Service account: praxis-centcom-calendar@unified-atom-492422-n5.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=


# ───── Integrations: Slack (notifications + webhook posts) ─────

SLACK_BOT_TOKEN=


# ───── Cron / programmatic auth ─────

# Any random ≥32-char string. Required by /api/integrations/*/sync routes
# when triggered without a Clerk session (Vercel cron, GitHub Actions).
# Generate: `openssl rand -hex 32`
CRON_SECRET=


# ───── Optional: seed script ─────

# Used by scripts/seed.ts to attribute seeded data to a known user.
CLERK_USER_ID=


# ─────────────────────────────────────────────────────────────────
# Not env vars — these live in the Supabase `app_config` table and
# are managed at runtime via /config:
#   REPORTING_AI_MAX_TOKENS, REPORTING_AI_MODEL, REPORTING_CONFIG_DEFAULTS,
#   REPORTING_DATE_PARSE_THRESHOLD, REPORTING_DEFAULT_FUNNEL_TYPE,
#   REPORTING_DEFAULT_KPI_COUNT, REPORTING_DEFAULT_TIMEFRAME,
#   REPORTING_FORECAST_DEFAULT_METHOD, REPORTING_FORECAST_DEFAULT_PERIODS,
#   REPORTING_GRANULARITY_THRESHOLDS_JSON
# ─────────────────────────────────────────────────────────────────
